# ByClan 환경 변수 템플릿
# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 값을 채워 넣으세요.
# .env.local 은 git에 커밋되지 않습니다 (.gitignore 에 의해 제외됨).

# Supabase 프로젝트 설정 (필수)
# Supabase 대시보드 → 프로젝트 설정 → API 탭에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY

# Sentry 오류 추적 (선택)
# NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_WITH_YOUR_SENTRY_DSN
