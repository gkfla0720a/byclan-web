# =====================================================================
# ByClan Web - 환경변수 예시 파일
# 이 파일을 복사하여 .env.local 로 저장한 뒤 값을 채워주세요.
# .env.local 은 Git에 커밋되지 않습니다.
# =====================================================================

# ── 홈게이트 설정 ──────────────────────────────────────────────────────
# 임시 접근 제한 활성화 여부 (개발 완료 시 false 로 변경)
NEXT_PUBLIC_HOME_GATE_ENABLED=true
# 홈게이트 접근 비밀번호 (숫자)
DEV_ACCESS_PASSWORD=your_password_here

# ── Supabase (공개 키 - 클라이언트 사이드) ────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Supabase (서버 사이드 - API Routes 전용) ──────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── PostgreSQL 직접 연결 (scripts/ 폴더 전용) ─────────────────────────
# Supabase 프로젝트 대시보드 > Settings > Database > Connection string (URI) 에서 확인
DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ── 에러 모니터링 (선택) ──────────────────────────────────────────────
# Sentry 프로젝트 DSN (없으면 콘솔 출력만, Sentry 미전송)
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
